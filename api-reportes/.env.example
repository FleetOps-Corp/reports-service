# API Reportes - Environment Variables Template
# Copy this file to .env and fill in actual values

# Application Configuration
APP_NAME=API Reportes
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# Server Configuration
API_HOST=0.0.0.0
API_PORT=8001
RELOAD=False

# MongoDB Atlas Configuration
# Format: mongodb+srv://username:password@cluster.mongodb.net
MONGODB_URL=mongodb+srv://fleetops_user:your_secure_password_here@reports-cluster.mongodb.net
MONGODB_DATABASE=reports_analytics

# gRPC Services Configuration
GRPC_VEHICLES_HOST=vehicles-service
GRPC_VEHICLES_PORT=50051

GRPC_INCIDENTS_HOST=incidents-service
GRPC_INCIDENTS_PORT=50052

GRPC_ASSIGNMENTS_HOST=assignments-service
GRPC_ASSIGNMENTS_PORT=50053

GRPC_MAINTENANCE_HOST=maintenance-service
GRPC_MAINTENANCE_PORT=50054

# Observability
PROMETHEUS_PORT=8002
ENABLE_METRICS=True

# Service Discovery
SERVICE_NAME=api-reportes
SERVICE_INSTANCE_ID=api-reportes-1
