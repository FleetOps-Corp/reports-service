# Gráficas y Estadísticas - Environment Variables
APP_NAME=Gráficas y Estadísticas
APP_VERSION=1.0.0
DEBUG=False
LOG_LEVEL=INFO

# Server
API_HOST=0.0.0.0
API_PORT=8002

# MongoDB
MONGODB_URL=mongodb+srv://fleetops_user:your_password@reports-cluster.mongodb.net
MONGODB_DATABASE=reports_analytics

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=reports
MINIO_USE_SSL=False

# Observability
PROMETHEUS_PORT=8003
ENABLE_METRICS=True

SERVICE_NAME=graficas-estadisticas
SERVICE_INSTANCE_ID=graficas-estadisticas-1
