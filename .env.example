# Variables de entorno para Reports Service

# ============= CONFIGURACIÓN GLOBAL =============
ENVIRONMENT=development
PROJECT_NAME=FleetOps-Reports-Service

# ============= API REPORTES =============
API_REPORTES_APP_NAME=API Reportes
API_REPORTES_VERSION=1.0.0
API_REPORTES_DEBUG=true
API_REPORTES_LOG_LEVEL=INFO

API_REPORTES_HOST=0.0.0.0
API_REPORTES_PORT=8001

# ============= GRÁFICAS Y ESTADÍSTICAS =============
GRAFICAS_APP_NAME=Gráficas y Estadísticas
GRAFICAS_VERSION=1.0.0
GRAFICAS_DEBUG=true
GRAFICAS_LOG_LEVEL=INFO

GRAFICAS_HOST=0.0.0.0
GRAFICAS_PORT=8002

# ============= MONGODB =============
MONGODB_URL=mongodb+srv://user:password@cluster.mongodb.net
MONGODB_DATABASE=reports_db
MONGODB_TIMEOUT=5000

# ============= MinIO =============
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=reports
MINIO_USE_SSL=false

# ============= gRPC =============
GRPC_PORT=50051
GRPC_TIMEOUT=10

# ============= PROMETHEUS =============
PROMETHEUS_PORT=8004
ENABLE_METRICS=true
METRICS_PORT=8005

# ============= LOGGING =============
LOG_FORMAT=json
LOG_LEVEL=INFO
LOG_FILE=/var/log/reports-service.log

# ============= SECURITY =============
JWT_SECRET=your-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION=3600

# ============= FEATURES =============
ENABLE_CIRCUIT_BREAKER=true
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60
